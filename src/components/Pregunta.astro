---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="step" data-step hidden>
  <div class="step__head">
    <h2 class="step__title">{title}</h2>
    {subtitle && <p class="step__subtitle">{subtitle}</p>}
  </div>
  <slot />
</section>

<style>
  .step {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step__head {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .step__title {
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .step__subtitle {
    font-size: 0.9375rem;
    color: var(--muted);
  }
</style>
